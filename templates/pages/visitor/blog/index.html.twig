 {% extends 'themes/base_visitor.html.twig' %}

{% block title %}Toutes nos recettes simples et rapides | Blog cuisine{% endblock %}

{% block description %}
    Parcourez toutes nos recettes de cuisine simples, rapides et faciles à préparer. 
    Trouvez des idées de repas pour le quotidien : entrées, plats, desserts et cuisine familiale.
{% endblock %}

{% block keywords %}
    <meta name="keywords" content="recettes simples, recettes rapides, idées repas faciles, cuisine maison, 
    recettes familiales, liste recettes, blog cuisine facile">

{% endblock %}

{# pour la pagination #}
{% block knp_paginator %}
	{{ knp_pagination_rel_links(recipes) }}
{% endblock %}


{% block main %}
   
    {% include 'components/visitor/_header_visitor.html.twig' with {'h1': "Toutes nos recettes simples et rapides"} %}
    <p class="text-center">
        🍴 Découvrez l'ensemble des recettes du blog : des idées faciles et gourmandes 
        pour cuisiner rapidement au quotidien.
    </p>

    <div class="container my-5">
     
		<div class="row">
			<div class="col-lg-8 mx-auto">
				<div class="d-flex justify-content-between flex-wrap gap-3">
					<div class="dropdown">
						<a class="btn btn-secondary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
							Les catégories
						</a>

						<ul class="dropdown-menu">
							{% if categories is not empty %}
								{% for category in categories %}
									<li>
										<a class="dropdown-item" href="{{path('app_visitor_blog_filter_by_category', {'id':category.id, 'slug':category.slug})}}">
											{{category.name}} ({{category.recipes|filter(r => r.isPublished)|length}} recette{{category.recipes|length > 1 ? 's' : ''}})
										</a>
									</li>
								{% endfor %}
							{% else %}
								<li><a class="dropdown-item" href="#">Aucune catégorie</a></li>
							{% endif %}
						</ul>
					</div>
				
					<div class="dropdown">
						<a class="btn btn-secondary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
							Les tags
						</a>

						<ul class="dropdown-menu">
							{% if tags is not empty %}
								{% for tag in tags %}
									<li>
										<a class="dropdown-item" href="{{path('app_visitor_blog_filter_by_tag', {'id':tag.id, 'slug':tag.slug})}}">
											{{tag.name}} ({{tag.recipes|filter(r => r.isPublished)|length}} recette{{tag.recipes|length > 1 ? 's' : ''}})
										</a>
									</li>
								{% endfor %}
							{% else %}
								<li><a class="dropdown-item" href="#">Aucun Tag</a></li>
							{% endif %}
						</ul>
					</div>

					<div class="dropdown">
						<a class="btn btn-secondary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
							Les ingrédients
						</a>

						<ul class="dropdown-menu">
							{% if ingredients is not empty %}
								{% for ingredient in ingredients %}
									<li>
										<a class="dropdown-item" href="{{path('app_visitor_blog_filter_by_ingredient', {'id':ingredient.id, 'slug':ingredient.slug})}}">
											{{ingredient.name}} ({{ingredient.recipes|filter(r => r.isPublished)|length}} recette{{ingredient.recipes|length > 1 ? 's' : ''}})
										</a>
									</li>
								{% endfor %}
							{% else %}
								<li><a class="dropdown-item" href="#">Aucun Ingrédient</a></li>
							{% endif %}
						</ul>
					</div>

				</div>
			</div>
		</div>


			<div class="container my-5">
				<div class="row">
					<div class="col-md-12 col-lg-8 mx-auto">
						{% for recipe in recipes %}
							<div class="card shadow my-5">
								<div class="row g-0">
									<div class="col-md-4">
										<img class="w-100 h-100 rounded-start" src="{{ vich_uploader_asset(recipe, 'imageFile') | imagine_filter('visitor_recipe_thumb') }}" alt="{{ recipe.title }}">
									</div>
									<div class="col-md-8">
										<div class="card-body">
											<h5 class="card-title">{{recipe.title|u.truncate('80', '...')}}</h5>
											<p class="card-text">Catégorie: <span class="badge text-bg-info">{{recipe.category.name}}</span></p>
											{% if recipe.tags is not empty %}
											<p class="card-text">
												Tags: 
												{% for tag in recipe.tags %}
													<span class="badge text-bg-secondary">{{tag.name}}</span>
												{% endfor %}
											</p>
											{% endif %}
											<p class="card-text"><small class="text-body-secondary">Publié {{recipe.publishedAt|ago}}</small></p>
											<a href="{{path('app_visitor_blog_recipe_show', {'id':recipe.id, 'slug':recipe.slug})}}" class="btn btn-primary shadow">Lire la recette</a>
										</div>
									</div>
								</div>
							</div>
						{% endfor %}

						{# display navigation #}
						<div class="d-flex justify-content-center align-items-center">
							{{ knp_pagination_render(recipes) }}
						</div>
					</div>
				</div>
			</div>
	</div>
{% endblock %}


 