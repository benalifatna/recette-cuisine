{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Mentions légales | Blog de recettes simples et rapides{% endblock %}

{% block description %}
    Consultez les mentions légales du blog de recettes simples et rapides de Sophie Lemoine.
    Informations sur l'éditeur du site, l'hébergement et la propriété intellectuelle.
{% endblock %}

{% block keywords %}
<meta name="keywords" content="mentions légales, blog cuisine, Sophie Lemoine, éditeur site, hébergement site web, recettes simples et rapides">
{% endblock %}

{% block main %}

    <h1 class="text-center my-3 display-5">
        Mentions légales
