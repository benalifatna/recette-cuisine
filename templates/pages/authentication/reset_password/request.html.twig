{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Réinitialisation du mot de passe{% endblock %}

{% block description %}
    Demandez la réinitialisation de votre mot de passe pour accéder à votre compte 
    sur le blog de recettes simples et rapides. Un lien sécurisé vous sera envoyé par email.
{% endblock %}

{% block keywords %}
    réinitialisation mot de passe, mot de passe oublié, 
    compte blog cuisine, recettes simples et rapides connexion
{% endblock %}

{% block main %}
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    <h1 class="text-center my-3 display-5">Réinitialisation du mot de passe</h1>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 col-lg-5 mx-auto shadow p-4">
                    {{ form_start(requestForm) }}
                    <div class="mb-3">
                        <label for="reset_password_request_form_email">Votre email</label>
                        <div class="text-danger">{{form_errors(requestForm.email)}}</div>
                        {{ form_widget(requestForm.email, {'attr': {'class':'form-control', 'autofocus': 'autofocus'}}) }}
                        <small>Entrer votre adresse email, et nous vous enverrons le lien de réinitialisation du mot de passe.</small>
                    </div>    
                    <div>
                        <button formnovalidate class="btn btn-primary w-100 shadow">Envoyer la demande</button>
                    </div>
                    {{ form_end(requestForm) }}

            </div>
        </div>
    </div>
{% endblock %}
