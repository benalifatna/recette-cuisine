<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Inscription - Le blog de Sophie Lemoine{% endblock %} - Le blog de Sophie Lemoine</title>
        {# Minimum du responsive design #}
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        
        {# SEO #}
        <meta name="robots" content="index, follow">
        <meta name="description" content="{% block description %}
        Inscrivez-vous gratuitement sur le blog de recettes simples et rapides de Sophie Lemoine 
        pour liker, noter vos recettes préférées, commenter et partager votre avis.
        {% endblock %}">
        <meta name="keywords" content="{% block keywords %}
        inscription blog cuisine, créer un compte recettes, recettes simples et rapides, 
        blog cuisine familiale, inscription gratuite
        {% endblock %}">
        <meta name="author" content="Sophie Lemoine">
        <meta name="publisher" content="Fatna Benali">
        <meta name="theme-color" content="#E63946">

        {# Favicon #}
                 
        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="shortcut icon" href="/favicon.ico">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="manifest" href="/site.webmanifest">
        
        {# Google Font #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Playfair:ital,opsz,wght@0,5..1200,300..900;1,5..1200,300..900&family=Playwrite+US+Modern:wght@100..400&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
        
        {# Font Awesome pour les icones#}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer">
        
        {# WebpackEncore stylesheets #}
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

         {# WebpackEncore javascripts #}
        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}

    </head>
<body class="sl-auth-bg">
    <main>
            <div class="container">
                <div class="row">
                    <div class="col-lg-6">
                        <img class="img-fluid" src="/images/statics/inscription-blog-sophie-lemoine.png" alt="Sophie Lemoine vous invite à vous inscrire">
                    </div>
                    <div class="col-lg-6 d-flex flex-column gap-3 justify-content-center align-items-center my-4">
                        <h1 class="text-center my-3">Inscription</h1>
                        

                        {% for flash_error in app.flashes('verify_email_error') %}
                            <div class="alert alert-danger text-center" role="alert">{{ flash_error }}</div>
                        {% endfor %}

                        {{form_start(registrationForm, {'attr': {'class':class="sl-auth-form"}})}}
                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="mb-3">
                                        <label for="registration_form_firstName">Prénom <span class="text-danger">*</span></label>
                                        <div class="text-danger">{{form_errors(registrationForm.firstName)}}</div>
                                        {{form_widget(registrationForm.firstName, {'attr': {'class':'form-control', 'autofocus':'autofocus'}})}}
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="mb-3">
                                        <label for="registration_form_lastName">Nom <span class="text-danger">*</span></label>
                                        <div class="text-danger">{{form_errors(registrationForm.lastName)}}</div>
                                        {{form_widget(registrationForm.lastName, {'attr': {'class':'form-control'}})}}
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="registration_form_email">Email <span class="text-danger">*</span></label>
                                    <div class="text-danger">{{form_errors(registrationForm.email)}}</div>
                                {{form_widget(registrationForm.email, {'attr': {'class':'form-control'}})}}
                            </div>
                            <div class="mb-3">
                                <label for="registration_form_password_first">Mot de passe <span class="text-danger">*</span></label>
                                <div class="text-danger">{{form_errors(registrationForm.password.first)}}</div>
                                {{form_widget(registrationForm.password.first, {'attr': {'class':'form-control', 'placeholder': 'Au moins 12 caractères'}})}}
                                <small><i class="text-warning fa-solid fa-triangle-exclamation"></i> Au moins une lettre minuscule, majuscule, un chiffre et un caractère spécial.</small>
                            </div>
                            <div class="mb-3">
                                <label for="registration_form_password_second">Confirmation du mot de passe <span class="text-danger">*</span></label>
                                <div class="text-danger">{{form_errors(registrationForm.password.second)}}</div>
                                {{form_widget(registrationForm.password.second, {'attr': {'class':'form-control'}})}}
                            </div>
                            <div class="mb-3">
                            <div class="text-danger">{{form_errors(registrationForm.agreeTerms)}}</div>
                                {{form_widget(registrationForm.agreeTerms)}} 
                                <label for="registration_form_agreeTerms">Lire et accepter <a href="{{path('app_visitor_terms_of_service')}}" target="_blank">les conditions générales d'utilisation</a></label>
                            </div>
                            <div>
                                <input formnovalidate type="submit" class="btn btn-primary w-100 shadow" value="S'inscrire">
                            </div>
                        {{form_end(registrationForm)}}
                     
                     
                     <div class="text-center">
                            <p>Vous avez déjà un compte? <a href="{{path('app_login')}}">Connectez-vous</a></p>
                            <p><a href="{{path('app_visitor_welcome')}}">Retour à l'accueil</a></p>
                     </div>
                    </div>
                     
                </div>
             </div>

    </main>
</body>
</html>





  
