{% extends "themes/base_admin.html.twig" %}

{% block title %}Gestion des recettes | Administration{% endblock %}

{% block description %}
Consultez et gérez les recettes du blog : entrées, plats, desserts 
et autres types de recettes simples et rapides.
{% endblock %}

{% block j_query %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
{% endblock %}

{% block data_tables %}
    <link href="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.css" rel="stylesheet" integrity="sha384-MnxpJFHU9dTMYXshJqBDA0d93sG4KKAFEEzynAaDqcPP7BYh11O5HxbJ6iLDWOXS" crossorigin="anonymous">
    
    <script src="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.js" integrity="sha384-7rAjATpiK3MtvKnoDf5WQz4O8W+3kpl4Jm82apgJgNkeUmZ59yjJT6LqlJpYqhVK" crossorigin="anonymous"></script>

    <script>
        $(document).ready( function () {
            $('#table').DataTable({
                // pour langue en français
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.3.7/i18n/fr-FR.json',
                }
            });
        } );
    </script>
{% endblock %}

{% block main %}
    <h1 class="text-center my-3 display-5">Liste des recettes</h1>

    {% include 'components/_alert.html.twig' %}

    <div class="d-flex justify-content-end align-items-center my-3">
    <a href="{{path('app_admin_recipe_create')}}" class="btn btn-primary shadow"><i class="fa-solid fa-plus"></i> Nouvelle recette</a>
    </div>

        
        <div class="table-responsive">
        <table id="table" class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Titre</th>
                    <th>Catégorie</th>
                    <th>Statut</th>
                    <th>Contenu</th>
                    <th>Crée le</th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>
                {% for recipe in recipes %}
                    <tr>
                    <td class="align-middle">
                            <div class="d-flex justify-content-center align-items-center gap-1">
                                    <img  src="{{ vich_uploader_asset(recipe, 'imageFile') | imagine_filter('admin_recipe_thumb') }}" alt="{{ recipe.title }}">
                            </div>
                        </td>
                        <td>{{recipe.title}}</td>
                        <td>{{recipe.category.name}}</td>
                        <td class="align-middle">
                            <div class="d-flex flex-column justify-content-center align-items-center gap-1 text-center">
                                {% if recipe.isPublished %}
                                {# format date objet  #}
                                    <p>Publié le {{recipe.publishedAt|format_date()}}</p>
                                {% else %}
                                    <p>Non publié</p>
                                {% endif %}
                                <form action="{{path('app_admin_recipe_publish', {'id':recipe.id})}}" method="POST">
                                    <input type="hidden" name="csrf_token" value="{{csrf_token('publish-recipe-'~recipe.id)}}">
                                    <div class="form-check form-switch">
                                        <input 
                                            class="form-check-input" 
                                            type="checkbox" 
                                            role="switch"
                                            onclick="return confirm('Confirmer cette action?')"
                                            onchange="this.form.submit();"
                                            {{ recipe.isPublished ? 'checked' : '' }}
                                        >
                                    </div>
                                </form>
                            </div>
                        </td>
                        <td>
                            <a href="{{path('app_admin_recipe_show', {'id':recipe.id})}}" class="btn btn-sm btn-dark">Lire</a>
                        </td>
                        <td>{{recipe.createdAt|format_date()}}</td>
                        <td class="align-middle">
                            <div class="d-flex justify-content-center align-items-center gap-1">
                                <a href="{{path('app_admin_recipe_edit', {'id':recipe.id})}}" class="btn btn-sm btn-secondary">Modifier</a>
                                <form action="{{path('app_admin_recipe_delete', {'id':recipe.id})}}" method="recipe">
                                    <input type="hidden" name="csrf_token" value="{{csrf_token('delete-recipe-'~recipe.id)}}">
                                    <input type="submit" class="btn btn-sm btn-danger" value="Supprimer" onclick="return confirm('Confirmer la suppression de cette recette ?')">
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}