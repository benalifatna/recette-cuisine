{% extends "themes/base_admin.html.twig" %}

{% block title %}Modifier une recette | Administration du blog de recettes{% endblock %}

{% block description %}
Page d'administration permettant de modifier une recette existante.
L'administrateur peut mettre à jour le titre, la catégorie (Entrées, Plats, Desserts, etc.),
la description, les mots clés, l'image et le contenu (les ingrédients, les étapes de préparation et les informations pratiques),
afin de garantir un contenu clair, structuré et optimisé pour l'utilisateur afin d'améliorer la navigation des utilisateurs..
{% endblock %}

{% block tiny_mce %}
    <script src="https://cdn.tiny.cloud/1/xcc280jrjj1yg308b36ikqxwzvvk420yzcvig7pq9e2f3lmq/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
    <script>
        tinymce.init({
            selector: 'textarea'
        });
    </script>
{% endblock %}

{% block j_query %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
{% endblock %}

{% block select2 %}
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
    $(document).ready(function() {
        $('#recipe_form_tags').select2();
    });
</script>
<script>
// quand on charge la page on a une fonction anonyme
    $(document).ready(function() {
        // on cherche dans la page, l'élement qui possède l'identifiant recipe_form_ingredients qui provient du fichier select2
        $('#recipe_form_ingredients').select2();
    });
</script>
{% endblock %}


{% block main %}
    <h1 class="text-center my-3 display-5">
        Modifier une recette de cuisine
    </h1>


        <p class="text-center">
            Utilisez ce formulaire pour modifier une recette 
            afin d'alimenter le blog.
        </p>
        
        <div class="container">
            <div class="row w-100">
                <div class="col-md-10 col-lg-5 mx-auto bg-light shadow p-4">
                        {{ form_start(recipeForm) }}
                            <div class="mb-3">
                                <label for="recipe_form_title">Titre <span class="text-danger">*</span></label>
                                <div class="text-danger">{{form_errors(recipeForm.title)}}</div>
                                {{ form_widget(recipeForm.title, {'attr': {'class':'form-control', 'autofocus':'autofocus'}}) }}
                            </div>
                            <div class="mb-3">
                                <label for="recipe_form_category">Catégorie <span class="text-danger">*</span></label>
                                <div class="text-danger">{{form_errors(recipeForm.category)}}</div>
                                {{ form_widget(recipeForm.category, {'attr': {'class':'form-control'}}) }}
                            </div>
                            <div class="mb-3">
                                <label for="recipe_form_tags">Tags</label>
                                <div class="text-danger">{{form_errors(recipeForm.tags)}}</div>
                                {{ form_widget(recipeForm.tags, {'attr': {'class':'form-control'}}) }}
                            </div>
                            <div class="mb-3">
                                <label for="recipe_form_ingredients">Ingrédient</label>
                                <div class="text-danger">{{form_errors(recipeForm.tags)}}</div>
                                {{ form_widget(recipeForm.ingredients, {'attr': {'class':'form-control'}}) }}
                            </div>
                            <div class="mb-3">
                                <label for="recipe_form_description">Description <span class="text-danger">*</span></label>
                                <div class="text-danger">{{form_errors(recipeForm.description)}}</div>
                                {{ form_widget(recipeForm.description, {'attr': {'class':'form-control'}}) }}
                            </div>
                            <div class="mb-3">
                                <label for="recipe_form_keywords">Mots clés</label>
                                <div class="text-danger">{{form_errors(recipeForm.keywords)}}</div>
                                {{form_widget(recipeForm.keywords, {'attr': {'class':'form-control'}})}}
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-4 text-center">
                                    <img  id="image-preview" src="{{ vich_uploader_asset(recipe, 'imageFile') | imagine_filter('admin_recipe_thumb') }}" alt="{{ recipe.title }}" class="img-fluid rounded shadow">
                                </div>
                                <div class="col-md-8">
                                    <label for="recipe_form_imageFile"><small class="text-muted">Vous pouvez conserver l'image actuelle ou en choisir une nouvelle.</small><span class="text-danger">*</span></label>
                                    <div class="text-danger">{{form_errors(recipeForm.imageFile)}}</div>
                                    {{form_widget(recipeForm.imageFile, {'attr': {'class':'form-control mb-3', 'onchange':'previewImage(event)'}})}}
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="recipe_form_content">Contenu</label>
                                <div class="text-danger">{{form_errors(recipeForm.content)}}</div>
                                {{form_widget(recipeForm.content, {'attr': {'class':'form-control', 'rows':10}})}}
                            </div>
                            <div>
                                <input formnovalidate type="submit" class="btn btn-primary text-white shadow" value="Enregistrer">
                            </div>
                        {{ form_end(recipeForm) }}
                </div>
            </div>
        </div>

<script>
function previewImage(event)
{
    const input = event.target;
    const preview = document.getElementById('image-preview');

    if (input.files && input.files[0]) {
        const reader = new FileReader();

        reader.onload = function(e) {
            preview.src = e.target.result;
        }

        reader.readAsDataURL(input.files[0]);
    }
}
</script>      
  
{% endblock %}