{% extends "themes/base_admin.html.twig" %}

{% block title %}Gestion de mon profil | Utilisateur{% endblock %}

{% block description %}
Gérez les informations de votre profil utilisateur : prénom, nom, adresse email
et mot de passe afin de sécuriser l'accès à l'utilisateur du blog de recettes.
{% endblock %}


{% block main %}
    <h1 class="text-center my-3 display-5">Mon profil</h1>

    <p class="text-center">
        Cette page vous permet de consulter et modifier vos informations personnelles.
        Vous pouvez mettre à jour votre prénom, votre nom, votre adresse email
        ainsi que votre mot de passe pour sécuriser votre compte utilisateur.
    </p>

    {% include 'components/_alert.html.twig' %}

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-10 col-lg-5 mx-auto p-4 shadow">
                {# <div>
                    <p><strong>Prénom</strong>: {{admin.firstName}}</p>
                    <p><strong>Nom</strong>: {{admin.lastName}}</p>
                    <p><strong>Email</strong>: {{admin.email}}</p>
                    <div>
                        <a href="" class="btn btn-sm btn-secondary">Modifier mon profil</a>
                        <a href="" class="btn btn-sm btn-dark">Modifier mon mot de passe</a>
                    </div>
                </div> #}
                <div>
                    <p><strong>Prénom</strong>: {{app.user.firstName}}</p>
                    <p><strong>Nom</strong>: {{app.user.lastName}}</p>
                    <p><strong>Email</strong>: {{app.user.email}}</p>
                    <div>
                        <a href="{{path('app_user_profile_edit')}}" class="btn btn-sm btn-secondary">Modifier mon profil</a>
                        <a href="{{path('app_user_profile_password_edit')}}" class="btn btn-sm btn-dark">Modifier mon mot de passe</a>
                    </div>
                </div>
            </div>
        
        </div>
    
