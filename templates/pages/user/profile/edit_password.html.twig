{% extends "themes/base_admin.html.twig" %}

{% block title %}Modifier mon Mot de passe | Utilisateur{% endblock %}

{% block description %}
Modifiez votre mot de passe utilisateur afin de renforcer la sécurité de votre compte
et protéger l'accès à l'espace Utilisateur du blog de recettes.
{% endblock %}


{% block main %}
    <h1 class="text-center my-3 display-5">Modifier mon mot de passe</h1>

    <p class="text-center">
        Utilisez ce formulaire pour changer votre mot de passe.
        Pour des raisons de sécurité, vous devez saisir votre mot de passe actuel
        avant d'enregistrer un nouveau mot de passe.
    </p>

    {% include 'components/_alert.html.twig' %}

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-10 col-lg-5 mx-auto p-4 shadow">
                {{form_start(passwordProfileForm)}}
                    <div class="mb-3">
                        <label for="edit_password_profile_form_currentPassword">Mot de passe actuel</label>
                        <div class="text-danger">{{form_errors(passwordProfileForm.currentPassword)}}</div>
                        {{form_widget(passwordProfileForm.currentPassword, {'attr': {'class':'form-control', 'autofocus': 'autofocus'}})}}
                    </div>
                    <div class="mb-3">
                        <label for="edit_password_profile_form_plainPassword_first">Nouveau mot de passe</label>
                        <div class="text-danger">{{form_errors(passwordProfileForm.password.first)}}</div>
                        {{form_widget(passwordProfileForm.password.first, {'attr': {'class':'form-control', 'placeholder': 'Au moins 12 caractères', 'autofocus':'autofocus'}})}}
                        <small>Au moins une lettre minuscule, majuscule, un chiffre et un caractère spécial.</small>
                        </div>
                    <div class="mb-3">
                        <label for="edit_password_profile_form_plainPassword_second">Confirmation du nouveau mot de passe</label>
                        <div class="text-danger">{{form_errors(passwordProfileForm.password.second)}}</div>
                        {{ form_widget(passwordProfileForm.password.second, {'attr': {'class':'form-control'}}) }}
                    </div>

                    <div>
                        <input formnovalidate type="submit" class="btn btn-primary shadow w-100" value="Modifier">
                    </div>
                {{form_end(passwordProfileForm)}}
            </div>
        
        </div>
    
    </div>

{% endblock %}